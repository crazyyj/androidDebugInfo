<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/platform_demo_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="平台 Fragment 切换"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_show_platform_red_fragment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="显示 Red Fragment" />

                <Button
                    android:id="@+id/btn_show_platform_blue_fragment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="显示 Blue Fragment" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 级 AlertDialog"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_activity_alert_basic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 基础 AlertDialog" />

            <Button
                android:id="@+id/btn_activity_alert_single_choice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 单选 AlertDialog" />

            <Button
                android:id="@+id/btn_activity_alert_multi_choice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 多选 AlertDialog" />

            <Button
                android:id="@+id/btn_activity_alert_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 列表 AlertDialog" />

            <Button
                android:id="@+id/btn_activity_alert_custom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Activity 自定义 AlertDialog" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity 级 PopupWindow"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_activity_popup_anchor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity Popup Anchor" />

            <Button
                android:id="@+id/btn_activity_popup_dropdown_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity showAsDropDown" />

            <Button
                android:id="@+id/btn_activity_popup_at_location_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Activity showAtLocation" />

            <Button
                android:id="@+id/btn_activity_popup_dismiss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Activity dismiss PopupWindow" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/platform_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#4D808080" />

</LinearLayout>
